# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (web enrichment search) ───────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Google Calendar (service account) ────────────────────────────────────────
# Leave blank to skip scheduling — all other phases work without it
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
INTERVIEWER_TIMEZONE=America/New_York

# ── Fireflies.ai ──────────────────────────────────────────────────────────────
# Optional — mock endpoint available at POST /api/mocks/fireflies
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
# DEV ONLY: routes ALL email here (required on Resend free tier)
RESEND_TO_OVERRIDE=you@youremail.com
ADMIN_EMAIL=admin@yourdomain.com

# ── Slack ─────────────────────────────────────────────────────────────────────
# Optional — onboarding DMs are fire-and-forget
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_HR_CHANNEL_ID=
SLACK_TEAM_ID=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET=any-secure-random-string
CRON_SECRET=any-secure-random-string
# Static Meet link for demo (Google Workspace needed for auto-generation)
DEFAULT_MEETING_LINK=
